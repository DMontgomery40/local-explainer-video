# OpenAI API key (for GPT-4 director and fallback TTS)
OPENAI_API_KEY=sk-...

# Anthropic API key (for Claude director)
ANTHROPIC_API_KEY=sk-ant-...

# Replicate API token (for image generation/edit and Qwen3 TTS)
REPLICATE_API_TOKEN=r8_...

# Optional: default image generation model
# IMAGE_MODEL=qwen/qwen-image-2512
# IMAGE_MODEL=google/imagen-4

# Optional: append EEG 10-20 anatomical guide text to image prompts
# USE_EEG_10_20_GUIDE=true

# Deterministic template pipeline (recommended)
# USE_TEMPLATE_PIPELINE=true

# Optional: if deterministic render fails and visual_prompt exists, allow legacy model fallback
# ALLOW_TEMPLATE_FALLBACK_TO_QWEN=false

# Template mode:
# development = allows non-production template candidates
# production = hard-fail if no production-ready template matches
# TEMPLATE_PIPELINE_MODE=development

# Director typed-output migration control
# If false, template mode requires director-native scene_type+structured_data output.
# ALLOW_DOWNSTREAM_SCENE_TYPER_FALLBACK=true

# Scene typer resilience controls
# SCENE_TYPER_REQUEST_TIMEOUT_SECONDS=120
# SCENE_TYPER_MAX_RETRIES=2
# SCENE_TYPER_RETRY_BACKOFF_SECONDS=1.5

# Compositor backend for deterministic pipeline
# TEMPLATE_COMPOSITOR_BACKEND=pillow
